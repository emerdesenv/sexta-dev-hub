NODE_ENV=development
PORT=3000

# Em Docker: mysql. No host local (sem compose): localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=sextadev
DB_PASSWORD=sextadev123
DB_NAME=sextadev

JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
AUTH_COOKIE_NAME=sdh_auth_token
AUTH_REFRESH_COOKIE_NAME=sdh_refresh_token
AUTH_ACCESS_EXPIRES_IN=15m
AUTH_REFRESH_TTL_MS=2592000000

FRONTEND_URL=https://app.momentodev.com,http://localhost,http://localhost:5173,http://127.0.0.1:5173
STUDENT_REQUIRE_APPROVAL=true
STUDENT_INVITE_CODE=
ACCOUNT_PURGE_DAYS=30
ACCOUNT_PURGE_INTERVAL_MS=21600000
RATE_LIMIT_COMMUNITY_TOPICS_MAX=8
RATE_LIMIT_COMMUNITY_REPLIES_MAX=20
RATE_LIMIT_COMMUNITY_REPORTS_MAX=20
RATE_LIMIT_COMMUNITY_VOTES_MAX=50
# Gamificação de comunidade (fase 2)
COMMUNITY_GAMIFICATION_ENABLED=true
COMMUNITY_GAMIFICATION_TOPIC_XP=8
COMMUNITY_GAMIFICATION_TOPIC_COINS=1
COMMUNITY_GAMIFICATION_REPLY_XP=5
COMMUNITY_GAMIFICATION_REPLY_COINS=1
COMMUNITY_GAMIFICATION_UPVOTE_XP=3
COMMUNITY_GAMIFICATION_UPVOTE_COINS=0
COMMUNITY_GAMIFICATION_BEST_REPLY_XP=15
COMMUNITY_GAMIFICATION_BEST_REPLY_COINS=3
COMMUNITY_GAMIFICATION_DAILY_CAP_TOPIC=2
COMMUNITY_GAMIFICATION_DAILY_CAP_REPLY=6
COMMUNITY_GAMIFICATION_DAILY_CAP_UPVOTE_RECEIVED=20
COMMUNITY_GAMIFICATION_DAILY_CAP_BEST_REPLY=2
COMMUNITY_GAMIFICATION_COOLDOWN_TOPIC_SECONDS=3600
COMMUNITY_GAMIFICATION_COOLDOWN_REPLY_SECONDS=180
COMMUNITY_GAMIFICATION_COOLDOWN_UPVOTE_SECONDS=0
COMMUNITY_GAMIFICATION_COOLDOWN_BEST_REPLY_SECONDS=0
COMMUNITY_GAMIFICATION_MIN_TOPIC_CHARS=40
COMMUNITY_GAMIFICATION_MIN_REPLY_CHARS=20

# Radar de Vagas Tech (backend)
# Provedores habilitados (csv): remotive,arbeitnow,adzuna,jooble,custom
# Ex.: ampliar cobertura BR: JOBS_PROVIDERS=adzuna,jooble
JOBS_PROVIDERS=remotive
JOBS_REMOTIVE_URL=https://remotive.com/api/remote-jobs
JOBS_REMOTIVE_API_KEY=
JOBS_ARBEITNOW_URL=https://www.arbeitnow.com/api/job-board-api
JOBS_ARBEITNOW_API_KEY=
JOBS_ADZUNA_APP_ID=
JOBS_ADZUNA_APP_KEY=
JOBS_ADZUNA_COUNTRY=br
JOBS_ADZUNA_PAGE=1
JOBS_ADZUNA_RESULTS_PER_PAGE=50
JOBS_ADZUNA_WHAT=
JOBS_ADZUNA_WHERE=

# Jooble REST API — chave em https://jooble.org/api/about
JOBS_JOOBLE_API_KEY=
JOBS_JOOBLE_KEYWORDS=desenvolvedor software
# Na API do Jooble use "Brazil" (ou deixe vazio → o código normaliza Brasil/br → Brazil)
JOBS_JOOBLE_LOCATION=Brazil
JOBS_JOOBLE_RADIUS=200
JOBS_JOOBLE_MAX_PAGES=2

# true = só grava vagas com sinal técnico (título/descrição/stacks). false = grava tudo que a API mandar.
JOBS_REQUIRE_TECH_SIGNAL=true

JOBS_SYNC_INTERVAL_MS=3600000

# ---------------------------------------------------------------------------
# Legado: ignorado se JOBS_PROVIDERS estiver definido. Só para provider
# "custom" em JOBS_PROVIDERS ou fallback quando JOBS_PROVIDERS está vazio.
# ---------------------------------------------------------------------------
JOBS_PROVIDER_URL=
JOBS_PROVIDER_API_KEY=
JOBS_PROVIDER_NAME=custom