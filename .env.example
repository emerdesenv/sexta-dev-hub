# =============================================================================
# Raiz do repositório — usado pelo Docker Compose
# =============================================================================
# - mysql / db_backup: MYSQL_*
# - docker-compose.prod.yml: DOMAIN, SSL_EMAIL, VITE_* (build do frontend)
#
# Toda configuração da API Node (JWT, jobs, gamificação comunidade, etc.)
# fica em backend/.env — ver backend/.env.example
# =============================================================================

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=sextadev
MYSQL_USER=sextadev
MYSQL_PASSWORD=change-me

# Produção (Traefik + Let's Encrypt). Em CI, alinhar com APP_DOMAIN se usar.
DOMAIN=app.example.com
SSL_EMAIL=ops@example.com

# Frontend (Vite). No build Docker de produção, hoje entram API + GitHub;
# demais VITE_* usam default no código se não passados no Dockerfile.
VITE_API_URL=/api
VITE_GITHUB_URL=https://github.com/seu-usuario/seu-repositorio
VITE_ENABLE_VLIBRAS=true
VITE_ENABLE_PDF_PREVIEW=true
